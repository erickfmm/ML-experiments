# ── Kaggle API Token ──────────────────────────────────────────────
# Generate your token at: https://www.kaggle.com/settings/api
# Click "Generate New Token" and paste the value here.
#
# Alternatively, place your kaggle.json at ~/.kaggle/kaggle.json
# (legacy method).
#
KAGGLE_API_TOKEN=

# ── Flask Web GUI (optional) ─────────────────────────────────────
# FLASK_SECRET_KEY=change-me-to-something-random
